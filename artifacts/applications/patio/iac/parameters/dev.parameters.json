{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "dev"
    },
    "location": {
      "value": "eastus",
      "metadata": {
        "comment": "US region only per comp-001 (data residency requirement)"
      }
    },
    "applicationName": {
      "value": "patio"
    },
    "resourceGroupName": {
      "value": "rg-patio-dev-eastus"
    },
    
    "vnetAddressPrefix": {
      "value": "10.0.0.0/16"
    },
    "webSubnetPrefix": {
      "value": "10.0.1.0/24"
    },
    "databaseSubnetPrefix": {
      "value": "10.0.2.0/24"
    },
    "cacheSubnetPrefix": {
      "value": "10.0.3.0/24"
    },
    
    "vmCount": {
      "value": 1,
      "metadata": {
        "comment": "Single VM for dev environment (no load balancer needed)"
      }
    },
    "vmSize": {
      "value": "Standard_B2s",
      "metadata": {
        "comment": "Burstable tier for cost optimization in dev (per compute-001 v2.0.0)"
      }
    },
    "vmAdminUsername": {
      "value": "azureuser"
    },
    "enableLoadBalancer": {
      "value": false,
      "metadata": {
        "comment": "No load balancer needed for single VM dev environment"
      }
    },
    
    "mysqlSkuName": {
      "value": "Standard_B1ms",
      "metadata": {
        "comment": "Burstable tier for dev environment cost optimization"
      }
    },
    "mysqlSkuTier": {
      "value": "Burstable"
    },
    "mysqlStorageSizeGB": {
      "value": 20,
      "metadata": {
        "comment": "Minimal storage for dev (scales in production)"
      }
    },
    "mysqlBackupRetentionDays": {
      "value": 7,
      "metadata": {
        "comment": "7-day retention per stor-001 v2.0.0"
      }
    },
    "mysqlVersion": {
      "value": "8.0.21"
    },
    "mysqlAdminUsername": {
      "value": "patiodbadmin"
    },
    
    "redisSku": {
      "value": "Basic",
      "metadata": {
        "comment": "Basic tier for dev (Standard in staging/prod)"
      }
    },
    "redisFamily": {
      "value": "C"
    },
    "redisCapacity": {
      "value": 0,
      "metadata": {
        "comment": "C0 = 250MB cache, sufficient for dev (~$15/month)"
      }
    },
    
    "storageAccountSku": {
      "value": "Standard_LRS",
      "metadata": {
        "comment": "Standard LRS per stor-001 v2.0.0 (non-critical tier)"
      }
    },
    "storageAccountKind": {
      "value": "StorageV2"
    },
    
    "keyVaultSku": {
      "value": "standard",
      "metadata": {
        "comment": "Standard tier (Premium with HSM if budget allows)"
      }
    },
    
    "enableMonitoring": {
      "value": true,
      "metadata": {
        "comment": "Enable Azure Monitor, Log Analytics, Application Insights (per obs-001)"
      }
    },
    "logRetentionDays": {
      "value": 90,
      "metadata": {
        "comment": "90-day retention per audit-001"
      }
    },
    
    "tags": {
      "value": {
        "Environment": "dev",
        "Application": "patio",
        "CostCenter": "engineering",
        "Compliance": "NIST-800-171",
        "Tier": "application",
        "Workload": "non-critical",
        "Owner": "platform-team",
        "ManagedBy": "bicep-iac"
      }
    },
    
    "monthlyBudgetLimit": {
      "value": 50,
      "metadata": {
        "comment": "Dev environment cost target <$50/month per cost-001 v2.0.0"
      }
    }
  }
}
